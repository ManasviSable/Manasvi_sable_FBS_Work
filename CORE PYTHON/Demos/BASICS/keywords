#pass
for i in range(1,10):
    if i%2 == 0:
        pass

#break
for i in range(1,5):
    if (i==3):
        break
    print(i)

#continue
for i in range (1,5):
    if (i==3):
        continue
    print(i)

#else
for i in range(1,100):
    if (i==50):
        break
    print(i)
else:
    print("Loop completed without break")